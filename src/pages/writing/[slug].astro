---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/Footer.astro";

export async function getStaticPaths() {
  const essays = await getCollection("writing", ({ data }) => !data.draft);
  return essays.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
---

<Layout title={`${entry.data.title} — Frank Niu`} description={entry.data.summary}>
  <article class="essay">
    <div class="container essay__inner">
      <a href="/writing" class="essay__back mono" data-reveal>← Writing</a>

      <header class="essay__head" data-reveal>
        <p class="label essay__meta">
          <span>{entry.data.category}</span>
          <span aria-hidden="true">·</span>
          <span>{fmt(entry.data.date)}</span>
        </p>
        <h1 class="display essay__title">{entry.data.title}</h1>
        {entry.data.summary && <p class="essay__summary">{entry.data.summary}</p>}
      </header>

      <hr class="rule essay__rule" />

      <div class="prose" data-reveal>
        <Content />
      </div>

      <a href="/writing" class="essay__back essay__back--bottom mono">← Back to writing</a>
    </div>
  </article>
  <Footer />
</Layout>

<style>
  .essay {
    padding-block: clamp(2rem, 1.5rem + 3vw, 3.5rem) clamp(2rem, 1rem + 3vw, 4rem);
  }
  .essay__inner {
    max-width: var(--maxw-read);
  }
  .essay__back {
    display: inline-block;
    font-size: var(--fs-small);
    color: var(--ink-dim);
    margin-bottom: clamp(1.75rem, 1rem + 2vw, 2.75rem);
    transition: color var(--dur-fast) var(--ease-out);
  }
  .essay__back:hover {
    color: var(--ink);
  }
  .essay__head {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }
  .essay__meta {
    display: flex;
    gap: 0.6rem;
    color: var(--ink-faint);
  }
  .essay__title {
    font-size: var(--fs-display);
    font-weight: 750;
    letter-spacing: -0.03em;
  }
  .essay__summary {
    font-size: var(--fs-lead);
    color: var(--ink-dim);
    line-height: 1.5;
  }
  .essay__rule {
    margin-block: clamp(1.75rem, 1rem + 2vw, 2.75rem);
  }
  .essay__back--bottom {
    margin-top: clamp(2.5rem, 1.5rem + 3vw, 4rem);
    margin-bottom: 0;
  }

  /* reading prose */
  .prose :global(p),
  .prose :global(ul),
  .prose :global(ol),
  .prose :global(blockquote) {
    margin-block: 1.15em;
  }
  .prose :global(p) {
    color: var(--ink);
    font-size: 1.125rem;
    line-height: 1.72;
  }
  .prose :global(em) {
    color: var(--ink-dim);
  }
  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-top: 2em;
    margin-bottom: 0.5em;
  }
  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    margin-top: 1.6em;
    margin-bottom: 0.4em;
  }
  .prose :global(blockquote) {
    border-left: 2px solid var(--accent);
    padding-left: 1.25rem;
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 500;
    line-height: 1.4;
    color: var(--ink);
  }
  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose :global(strong) {
    font-weight: 600;
  }
</style>
